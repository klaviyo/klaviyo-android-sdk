<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
          Middleware activity to automatically handle Klaviyo intents such as
          App Links from Klaviyo click tracking domains and notification opens.
        -->
        <activity
                android:name="com.klaviyo.analytics.linking.KlaviyoMiddlewareActivity"
                android:excludeFromRecents="true"
                android:exported="false"
                android:launchMode="singleTask"
                android:noHistory="true"
                android:taskAffinity="${applicationId}.klaviyo.deeplink"
                android:theme="@android:style/Theme.Translucent.NoTitleBar" />

    </application>
</manifest>
